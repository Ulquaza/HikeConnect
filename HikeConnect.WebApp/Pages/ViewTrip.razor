@page "/trip/{id:guid}"

@attribute [Authorize]

@inject JwtAuthStateProvider Auth
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Поход - HikeConnect</PageTitle>

@if (_isLoading)
{
    <div class="view-trip-page">
        <p class="view-trip-loading">Загружаем поход...</p>
    </div>
}
else if (_trip is null)
{
    <div class="view-trip-page">
        <p class="view-trip-loading">Поход не найден.</p>
    </div>
}
else
{
    <div class="view-trip-page">
        <section class="view-trip-hero">
            <img src="/images/tripMain.jpeg" alt="Маршрут похода" class="view-trip-hero-image" />
            <div class="view-trip-hero-overlay"></div>

            <div class="view-trip-hero-content">
                <h1>@_trip.Name</h1>
                <p>Старт: @_trip.StartAt.ToString("dd.MM.yyyy")</p>
            </div>

            @if (_isAuthor)
            {
                <button type="button"
                        class="view-trip-join-button"
                        disabled="@_isTripStatusChanging"
                        @onclick="ToggleTripPublishStateAsync">
                    @_tripPublishButtonText
                </button>
            }
            else
            {
                <button type="button"
                        class="view-trip-join-button"
                        disabled="@(_isJoining || (_myPendingRequestId is null && _trip.Status != TripStatus.Planned))"
                        @onclick="ToggleParticipationAsync">
                    @if (_isJoining)
                    {
                        <span>Отправляем...</span>
                    }
                    else if (_myPendingRequestId.HasValue)
                    {
                        <span>Отменить заявку</span>
                    }
                    else if (_trip.Status != TripStatus.Planned)
                    {
                        <span>Набор закрыт</span>
                    }
                    else
                    {
                        <span>Присоединиться</span>
                    }
                </button>
            }
        </section>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <p class="view-trip-status">@_statusMessage</p>
        }

        <section class="card view-trip-description">
            <h2>Описание</h2>
            <p>@_trip.Description</p>
        </section>

        @if (!_isAuthor)
        {
            <section class="view-trip-compatibility">
                <div class="view-trip-compatibility-circle"
                     style="--compatibility-percent:@($"{_compatibilityPercentage}%");">
                    <div class="view-trip-compatibility-inner">
                        <div class="view-trip-compatibility-value">@_compatibilityPercentage%</div>
                        <div class="view-trip-compatibility-label">Совместимость</div>
                    </div>
                </div>
            </section>

            <section class="card view-trip-risks">
                <h2>Анализ рисков</h2>

                @if (_riskScales.Count == 0 && _matchScales.Count == 0)
                {
                    <p class="view-trip-empty">Существенных рисков не выявлено.</p>
                }
                else
                {
                    @if (_riskScales.Count == 0)
                    {
                        <p class="view-trip-empty">Существенных рисков не выявлено.</p>
                    }
                    @foreach (var scale in _riskScales)
                    {
                        <div class="view-trip-risk-item">
                            <div class="view-trip-risk-head">
                                <span>@scale.Title</span>
                                <span>@scale.Percent%</span>
                            </div>
                            <div class="view-trip-risk-track">
                                <div class="view-trip-risk-fill" style="width:@($"{scale.Percent}%");"></div>
                            </div>
                            <p>@scale.Message</p>
                        </div>
                    }
                    @foreach (var scale in _matchScales)
                    {
                        <div class="view-trip-risk-item view-trip-risk-item--match">
                            <div class="view-trip-risk-head">
                                <span>@scale.Title</span>
                                <span>@scale.Percent%</span>
                            </div>
                            <div class="view-trip-risk-track">
                                <div class="view-trip-risk-fill view-trip-risk-fill--match" style="width:@($"{scale.Percent}%");"></div>
                            </div>
                            <p>@scale.Message</p>
                        </div>
                    }
                }
            </section>
        }

        <section class="card view-trip-members">
            <h2>Участники похода</h2>
            <div class="view-trip-users-row">
                @if (_approvedParticipants.Count == 0)
                {
                    <p class="view-trip-empty">Пока нет принятых участников.</p>
                }
                else
                {
                    @foreach (var participant in _approvedParticipants)
                    {
                        <div class="view-trip-user">
                            <div class="view-trip-avatar-wrap">
                                <img src="/images/default_avatar.webp"
                                     class="view-trip-avatar-image"
                                     alt="@($"Аватар пользователя {participant.DisplayName}")" />
                                @if (_isAuthor && participant.RequestId != Guid.Empty)
                                {
                                    <button type="button"
                                            class="view-trip-reject-button"
                                            disabled="@_processingRequestIds.Contains(participant.RequestId)"
                                            aria-label="@($"Отклонить {participant.DisplayName}")"
                                            @onclick="() => RejectRequestAsync(participant.RequestId)">
                                        ×
                                    </button>
                                }
                            </div>
                            @if (string.IsNullOrWhiteSpace(participant.UserName))
                            {
                                <div class="view-trip-user-name">@participant.DisplayName</div>
                            }
                            else
                            {
                                <a class="view-trip-user-name view-trip-user-link" href="@($"/user/{participant.UserName}")">
                                    @participant.DisplayName
                                </a>
                            }
                        </div>
                    }
                }
            </div>
        </section>

        @if (_isAuthor)
        {
            <section class="card view-trip-pending">
                <h2>Ожидают принятия</h2>
                <div class="view-trip-users-row">
                    @if (_pendingParticipants.Count == 0)
                    {
                        <p class="view-trip-empty">Нет заявок в ожидании.</p>
                    }
                    else
                    {
                        @foreach (var participant in _pendingParticipants)
                        {
                            <div class="view-trip-user">
                                <div class="view-trip-avatar-wrap">
                                    <button type="button"
                                            class="view-trip-avatar-button"
                                            disabled="@_processingRequestIds.Contains(participant.RequestId)"
                                            title="Нажми, чтобы принять заявку"
                                            @onclick="() => ApproveRequestAsync(participant.RequestId)">
                                        <img src="/images/default_avatar.webp"
                                             class="view-trip-avatar-image view-trip-avatar-image--pending"
                                             alt="@($"Аватар пользователя {participant.DisplayName}")" />
                                    </button>
                                    <button type="button"
                                            class="view-trip-reject-button"
                                            disabled="@_processingRequestIds.Contains(participant.RequestId)"
                                            aria-label="@($"Отклонить {participant.DisplayName}")"
                                            @onclick="() => RejectRequestAsync(participant.RequestId)">
                                        ×
                                    </button>
                                </div>
                                @if (string.IsNullOrWhiteSpace(participant.UserName))
                                {
                                    <div class="view-trip-user-name">@participant.DisplayName</div>
                                }
                                else
                                {
                                    <a class="view-trip-user-name view-trip-user-link" href="@($"/user/{participant.UserName}")">
                                        @participant.DisplayName
                                    </a>
                                }
                            </div>
                        }
                    }
                </div>
            </section>
        }
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Trip? _trip;
    private CompatibilityReport? _compatibilityReport;
    private int _compatibilityPercentage;
    private bool _isLoading = true;
    private bool _isJoining;
    private bool _isTripStatusChanging;
    private bool _isAuthor;
    private Guid? _myPendingRequestId;
    private string _statusMessage = string.Empty;
    private string _tripPublishButtonText = "Закрыть набор";
    private readonly List<TripParticipantViewModel> _approvedParticipants = [];
    private readonly List<TripParticipantViewModel> _pendingParticipants = [];
    private readonly List<RiskScaleViewModel> _riskScales = [];
    private readonly List<RiskScaleViewModel> _matchScales = [];
    private readonly HashSet<Guid> _processingRequestIds = [];

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _statusMessage = string.Empty;
        _approvedParticipants.Clear();
        _pendingParticipants.Clear();
        _myPendingRequestId = null;
        _riskScales.Clear();
        _matchScales.Clear();
        _compatibilityReport = null;
        _compatibilityPercentage = 0;

        await LoadTripAsync();

        if (_trip is not null)
        {
            _isAuthor = _trip.AuthorId == Auth.UserId;
            SyncTripActionButtonText();
            await LoadParticipationRequestsAsync();

            if (!_isAuthor)
            {
                await EnsureCompatibilityReportAsync();
            }
        }

        _isLoading = false;
    }

    private async Task LoadTripAsync()
    {
        _trip = await Http.GetFromJsonAsync<Trip>($"{ApiRoutes.Trip.ById}{Id}");
    }

    private async Task LoadParticipationRequestsAsync()
    {
        if (_trip is null)
        {
            return;
        }

        _approvedParticipants.Clear();
        _pendingParticipants.Clear();
        _myPendingRequestId = null;

        var requests = await Http.GetFromJsonAsync<List<ParticipationRequestDto>>($"{ApiRoutes.ParticipationRequest.ByTripId}{_trip.Id}") ?? [];
        var authorDisplayName = !string.IsNullOrWhiteSpace(_trip.Author?.FullName)
            ? _trip.Author.FullName
            : !string.IsNullOrWhiteSpace(_trip.Author?.UserName)
                ? _trip.Author.UserName
                : "Организатор";

        _approvedParticipants.Add(new TripParticipantViewModel(Guid.Empty, authorDisplayName, _trip.Author?.UserName));

        foreach (var request in requests)
        {
            if (request.UserId == Guid.Empty)
            {
                continue;
            }

            var displayName = ResolveDisplayName(request);

            if (request.Status == ParticipationRequestStatus.Approved)
            {
                _approvedParticipants.Add(new TripParticipantViewModel(request.Id, displayName, request.UserName));
            }
            else if (request.Status == ParticipationRequestStatus.Pending)
            {
                if (_isAuthor)
                {
                    _pendingParticipants.Add(new TripParticipantViewModel(request.Id, displayName, request.UserName));
                }

                if (request.UserId == Auth.UserId)
                {
                    _myPendingRequestId = request.Id;
                }
            }
        }
    }

    private void SyncTripActionButtonText()
    {
        if (_trip is null)
        {
            _tripPublishButtonText = "Закрыть набор";
            return;
        }

        _tripPublishButtonText = _trip.Status == TripStatus.Ongoing
            ? "Открыть набор"
            : "Закрыть набор";
    }

    private async Task EnsureCompatibilityReportAsync()
    {
        if (_trip is null)
        {
            return;
        }

        var response = await Http.PostAsync($"{ApiRoutes.CompatibilityReport.Base}/{_trip.AuthorId}", content: null);
        if (response.IsSuccessStatusCode)
        {
            _compatibilityReport = await response.Content.ReadFromJsonAsync<CompatibilityReport>();
        }

        if (_compatibilityReport is null)
        {
            _compatibilityReport = await Http.GetFromJsonAsync<CompatibilityReport>($"{ApiRoutes.CompatibilityReport.ByTargetId}{_trip.AuthorId}");
        }

        if (_compatibilityReport is null)
        {
            return;
        }

        _compatibilityPercentage = Math.Clamp(_compatibilityReport.CompatibilityPercentage, 0, 100);

        var riskPoints = _compatibilityReport.RiskPoints?.ToList() ?? [];
        var matchPoints = _compatibilityReport.MatchPoints?.ToList() ?? [];

        var allWeights = riskPoints.Select(p => p.Weight).Concat(matchPoints.Select(p => p.Weight)).ToList();
        if (allWeights.Count == 0)
        {
            return;
        }

        var maxWeight = Math.Max(1, allWeights.Max());

        foreach (var point in riskPoints)
        {
            var percent = Math.Clamp((int)Math.Round(point.Weight * 100d / maxWeight), 5, 100);
            _riskScales.Add(new RiskScaleViewModel(
                Title: ResolvePointTitle(point),
                Message: point.Message,
                Percent: percent));
        }

        foreach (var point in matchPoints)
        {
            var percent = Math.Clamp((int)Math.Round(point.Weight * 100d / maxWeight), 5, 100);
            _matchScales.Add(new RiskScaleViewModel(
                Title: ResolvePointTitle(point),
                Message: point.Message,
                Percent: percent));
        }
    }

    private async Task ToggleParticipationAsync()
    {
        if (_trip is null || _isJoining)
        {
            return;
        }

        if (_myPendingRequestId is null && _trip.Status != TripStatus.Planned)
        {
            _statusMessage = "Набор в группу закрыт.";
            return;
        }

        _isJoining = true;
        _statusMessage = string.Empty;

        if (_myPendingRequestId.HasValue)
        {
            var cancelResponse = await Http.PatchAsync(ApiRoutes.ParticipationRequest.Cancel(_myPendingRequestId.Value), content: null);
            _statusMessage = cancelResponse.IsSuccessStatusCode
                ? "Заявка отменена."
                : "Не удалось отменить заявку.";
        }
        else
        {
            var joinResponse = await Http.PostAsync($"{ApiRoutes.ParticipationRequest.ById}{_trip.Id}", content: null);
            if (joinResponse.IsSuccessStatusCode)
            {
                var createdOrExistingRequest = await joinResponse.Content.ReadFromJsonAsync<ParticipationRequestDto>();
                _statusMessage = createdOrExistingRequest?.Status == ParticipationRequestStatus.Rejected
                    ? "Организатор ранее отклонил вашу заявку для этого похода."
                    : "Заявка отправлена организатору.";
            }
            else
            {
                _statusMessage = "Не удалось отправить заявку. Возможно, она уже существует.";
            }
        }

        await LoadParticipationRequestsAsync();

        _isJoining = false;
    }

    private async Task ToggleTripPublishStateAsync()
    {
        if (_trip is null || _isTripStatusChanging)
        {
            return;
        }

        _isTripStatusChanging = true;
        _statusMessage = string.Empty;

        var isClosed = _trip.Status == TripStatus.Ongoing;
        var route = isClosed
            ? ApiRoutes.Trip.Publish(_trip.Id)
            : ApiRoutes.Trip.Unpublish(_trip.Id);

        var response = await Http.PatchAsync(route, content: null);
        if (response.IsSuccessStatusCode)
        {
            var updatedTrip = await response.Content.ReadFromJsonAsync<Trip>();
            if (updatedTrip is not null)
            {
                _trip = updatedTrip;
            }

            SyncTripActionButtonText();
            _statusMessage = isClosed ? "Набор открыт." : "Набор закрыт.";
        }
        else
        {
            _statusMessage = "Не удалось обновить статус набора.";
        }

        _isTripStatusChanging = false;
    }

    private async Task ApproveRequestAsync(Guid requestId)
    {
        if (!_processingRequestIds.Add(requestId))
        {
            return;
        }

        _statusMessage = string.Empty;
        var response = await Http.PatchAsync(ApiRoutes.ParticipationRequest.Approve(requestId), content: null);
        if (response.IsSuccessStatusCode)
        {
            var approvedRequest = await response.Content.ReadFromJsonAsync<ParticipationRequestDto>();
            var approvedParticipant = _pendingParticipants.FirstOrDefault(item => item.RequestId == requestId);

            if (approvedParticipant is not null)
            {
                _pendingParticipants.Remove(approvedParticipant);
                _approvedParticipants.Add(approvedParticipant);
            }
            else if (approvedRequest is not null)
            {
                _approvedParticipants.Add(new TripParticipantViewModel(requestId, ResolveDisplayName(approvedRequest), approvedRequest.UserName));
            }
        }
        else
        {
            _statusMessage = "Не удалось принять заявку.";
        }

        _processingRequestIds.Remove(requestId);
    }

    private async Task RejectRequestAsync(Guid requestId)
    {
        if (!_processingRequestIds.Add(requestId))
        {
            return;
        }

        _statusMessage = string.Empty;
        var response = await Http.PatchAsync(ApiRoutes.ParticipationRequest.Reject(requestId), content: null);
        if (response.IsSuccessStatusCode)
        {
            _pendingParticipants.RemoveAll(item => item.RequestId == requestId);
            _approvedParticipants.RemoveAll(item => item.RequestId == requestId);

            if (_myPendingRequestId == requestId)
            {
                _myPendingRequestId = null;
            }
        }
        else
        {
            _statusMessage = "Не удалось отклонить заявку.";
        }

        _processingRequestIds.Remove(requestId);
    }

    private static string ResolveDisplayName(ParticipationRequestDto? request)
    {
        if (!string.IsNullOrWhiteSpace(request?.UserFullName))
        {
            return request.UserFullName;
        }

        if (!string.IsNullOrWhiteSpace(request?.UserName))
        {
            return request.UserName;
        }

        return "Участник";
    }

    private static string ResolvePointTitle(CompatibilityPoint point)
    {
        if (!string.IsNullOrWhiteSpace(point.Label))
        {
            return point.Label;
        }

        return HumanizeCode(point.Code);
    }

    private static string HumanizeCode(string? code)
    {
        if (string.IsNullOrWhiteSpace(code))
        {
            return "Параметр";
        }

        return code.Replace('_', ' ');
    }

    private sealed record TripParticipantViewModel(Guid RequestId, string DisplayName, string? UserName);
    private sealed record RiskScaleViewModel(string Title, string Message, int Percent);

}
