@page "/register"

@using System.Text.Json

@inject HttpClient Http
@inject JwtAuthStateProvider Auth
@inject NavigationManager Nav

<PageTitle>Регистрация - HikeConnect</PageTitle>

<div class="container">
    <div class="card auth-card">
        <div class="auth-content">
            <h2>Регистрация</h2>

            <EditForm Model="@_registerRequest" OnSubmit="@HandleRegisterSubmitAsync" class="auth-form">
                <div class="auth-field">
                    <label for="fullName">Отображаемое имя</label>
                    <InputText id="fullName" @bind-Value="_registerRequest.FullName" class="auth-input" />
                </div>

                <div class="auth-field">
                    <label for="username">Имя пользователя</label>
                    <InputText id="username" @bind-Value="_registerRequest.Username" class="auth-input" />
                </div>

                <div class="auth-field">
                    <label for="email">Email</label>
                    <InputText id="email" @bind-Value="_registerRequest.Email" class="auth-input" />
                </div>

                <div class="auth-field">
                    <label for="password">Пароль</label>
                    <InputText id="password" @bind-Value="_registerRequest.Password" type="password" class="auth-input" />
                </div>

                <button type="submit" class="auth-button">Создать аккаунт</button>
            </EditForm>

            @if (!string.IsNullOrWhiteSpace(_statusMessage))
            {
                <p class="auth-status">@_statusMessage</p>
            }

            <div class="auth-links">
                <NavLink href="/login">Уже есть аккаунт? Войти</NavLink>
                <NavLink href="/">На главную</NavLink>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly RegisterRequest _registerRequest = new()
    {
        FullName = string.Empty,
        Username = string.Empty,
        Email = string.Empty,
        Password = string.Empty
    };

    private string _statusMessage = string.Empty;

    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web);

    private async Task HandleRegisterSubmitAsync()
    {
        var response = await Http.PostAsJsonAsync(ApiRoutes.Auth.Register, _registerRequest);
        var registerJson = await response.Content.ReadAsStringAsync();
        RegisterResponse? content = TryDeserialize<RegisterResponse>(registerJson, out var registerParseError);

        if (registerParseError is not null)
        {
            _statusMessage = $"Не удалось разобрать ответ сервера ({(int)response.StatusCode}). Проверь, что API доступен по адресу из настроек.";
            return;
        }

        if (response.IsSuccessStatusCode && content?.IsRegistered is true)
        {
            var loginResponse = await Http.PostAsJsonAsync(ApiRoutes.Auth.Login, new LoginRequest
            {
                EmailOrUsername = _registerRequest.Username,
                Password = _registerRequest.Password
            });
            var loginJson = await loginResponse.Content.ReadAsStringAsync();
            LoginResponse? loginContent = TryDeserialize<LoginResponse>(loginJson, out var loginParseError);

            if (loginParseError is not null)
            {
                _statusMessage = "Аккаунт создан, но ответ при входе не распознан. Войди вручную.";
                Nav.NavigateTo("/login");
                return;
            }

            if (loginResponse.IsSuccessStatusCode && loginContent?.IsLoggedIn is true && !string.IsNullOrWhiteSpace(loginContent.AccessToken))
            {
                Auth.Login(loginContent.AccessToken);
                Nav.NavigateTo("/survey");
                return;
            }

            _statusMessage = "Аккаунт создан, но войти автоматически не удалось. Войди вручную.";
            Nav.NavigateTo("/login");
        }
        else
        {
            _statusMessage = content?.ErrorMessage ?? "Ошибка регистрации.";
        }
    }

    private static T? TryDeserialize<T>(string json, out string? error)
    {
        error = null;
        if (string.IsNullOrWhiteSpace(json))
        {
            error = "empty";
            return default;
        }

        try
        {
            return JsonSerializer.Deserialize<T>(json, JsonOptions);
        }
        catch (JsonException)
        {
            error = "parse";
            return default;
        }
    }
}
