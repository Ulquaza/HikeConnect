@page "/"

@inject HttpClient Http
@inject JwtAuthStateProvider Auth
@inject NavigationManager Navigation

<PageTitle>Главная - HikeConnect</PageTitle>

<div class="hero">
    <h1 class="hero-title">
        Найди свою походную группу по <span class="accent">вайбу</span>, а не только по темпу
    </h1>

    <p class="hero-subtitle">
        Мы используем поведенческую психологию, чтобы подбирать тебе напарников по походам,
        с которыми совпадают энергия общения и подход к маршруту
    </p>

    <button class="hero-button" @onclick="GoToLogin">
        Найти свою группу
    </button>
</div>

<div class="style-section">
    <h2 class="style-title">КАКОЙ У ТЕБЯ СТИЛЬ ПОХОДОВ?</h2>

    <div class="style-cards">
        <div class="style-card">
            <img src="/images/silent.webp" alt="Silent" class="style-icon" />
            <div class="style-text">ТИХИЙ</div>
        </div>

        <div class="style-card">
            <img src="/images/social.webp" alt="Social" class="style-icon" />
            <div class="style-text">ОБЩИТЕЛЬНЫЙ</div>
        </div>

        <div class="style-card">
            <img src="/images/sporty.webp" alt="Sporty" class="style-icon" />
            <div class="style-text">СПОРТИВНЫЙ</div>
        </div>
    </div>
</div>

<div class="how-section">
    <div class="how-steps">
        <div class="how-step">
            <div class="step-number">1</div>
            <h3>Создай профиль походника</h3>
            <p>Расскажи о своём опыте, стиле походов и ожиданиях от команды</p>
        </div>

        <div class="how-step">
            <div class="step-number">2</div>
            <h3>Пройди поведенческий опрос</h3>
            <p>Мы определим твой стиль принятия решений, отношение к риску и взаимодействию в группе</p>
        </div>

        <div class="how-step">
            <div class="step-number">3</div>
            <h3>Найди совместимых напарников</h3>
            <p>Сервис покажет людей, с которыми у тебя совпадают темп, подход и «вайб»</p>
        </div>
    </div>
</div>

<div class="trips-section">
    <h2 class="trips-title">Предстоящие походы</h2>

    <div class="trips-grid">
        @foreach (var trip in _trips)
        {
            <TripCard Trip="@trip" ViewerUserId="@ViewerUserId" />
        }
    </div>
</div>

<div class="cta-section">
    <div class="cta-content">
        <div class="cta-line"></div>

        <h2 class="cta-title">
            ГОТОВ НАЙТИ СВОЮ ПОХОДНУЮ КОМАНДУ?
        </h2>

        <button class="cta-button" @onclick="GoToLogin">
            Присоединиться
        </button>

        <div class="cta-line"></div>
    </div>
</div>

@code {
    private readonly List<Trip> _trips = [];
    private Guid? ViewerUserId => Auth.UserId == Guid.Empty ? null : Auth.UserId;

    protected override async Task OnInitializedAsync()
    {
        var trips = await Http.GetFromJsonAsync<List<Trip>>(ApiRoutes.Trip.Base) ?? [];
        _trips.Clear();
        _trips.AddRange(trips.OrderBy(trip => trip.StartAt));
    }

    void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }
}
