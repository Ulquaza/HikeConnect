@page "/trips"

@inject HttpClient Http
@inject JwtAuthStateProvider Auth

<PageTitle>Походы - HikeConnect</PageTitle>

<div class="trips-page">
    <div class="trips-layout">
        <aside class="trips-filters">
            <h2>Фильтры</h2>

            <label class="filter-checkbox">
                <InputCheckbox @bind-Value="onlyHighCompatibility" />
                <span>Совпадение по вайбу >80%</span>
            </label>
        </aside>

        <section class="trips-results">
            <h2 class="trips-title">Предстоящие походы</h2>

            <div class="trips-grid">
                @foreach (var trip in FilteredTrips)
                {
                    <TripCard Trip="@trip" ViewerUserId="@ViewerUserId" />
                }
            </div>
        </section>
    </div>
</div>


@code {
    private bool onlyHighCompatibility;
    private readonly List<Trip> _trips = [];
    private readonly Dictionary<Guid, int> _compatibilityByTripId = new();
    private Guid? ViewerUserId => Auth.UserId == Guid.Empty ? null : Auth.UserId;

    private IEnumerable<Trip> FilteredTrips =>
        onlyHighCompatibility
            ? _trips.Where(trip => _compatibilityByTripId.TryGetValue(trip.Id, out var percent) && percent > 80)
            : _trips;

    protected override async Task OnInitializedAsync()
    {
        var trips = await Http.GetFromJsonAsync<List<Trip>>(ApiRoutes.Trip.Base) ?? [];
        _trips.Clear();
        _trips.AddRange(trips.OrderBy(trip => trip.StartAt));

        if (ViewerUserId is null || ViewerUserId == Guid.Empty)
        {
            return;
        }

        foreach (var trip in _trips)
        {
            if (trip.AuthorId == ViewerUserId.Value)
            {
                _compatibilityByTripId[trip.Id] = 100;
                continue;
            }

            try
            {
                var response = await Http.PostAsync($"{ApiRoutes.CompatibilityReport.Base}/{trip.AuthorId}", content: null);
                if (response.IsSuccessStatusCode)
                {
                    var report = await response.Content.ReadFromJsonAsync<CompatibilityReport>();
                    if (report is not null)
                    {
                        _compatibilityByTripId[trip.Id] = Math.Clamp(report.CompatibilityPercentage, 0, 100);
                    }
                }
                else
                {
                    var report = await Http.GetFromJsonAsync<CompatibilityReport>($"{ApiRoutes.CompatibilityReport.ByTargetId}{trip.AuthorId}");
                    if (report is not null)
                    {
                        _compatibilityByTripId[trip.Id] = Math.Clamp(report.CompatibilityPercentage, 0, 100);
                    }
                }
            }
            catch
            {
                // keep missing compatibility as not matched for filter
            }
        }
    }
}
