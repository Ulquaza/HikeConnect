@page "/login"

@inject HttpClient Http
@inject JwtAuthStateProvider Auth
@inject NavigationManager Nav

<PageTitle>Вход - HikeConnect</PageTitle>

<div class="container">
    <div class="card auth-card">
        <div class="auth-content">
            <h2>Вход</h2>

            <EditForm Model="@_loginRequest" OnSubmit="@HandleLoginSubmitAsync" class="auth-form">
                <div class="auth-field">
                    <label for="emailOrUsername">Email или логин</label>
                    <InputText id="emailOrUsername" @bind-Value="_loginRequest.EmailOrUsername" class="auth-input" />
                </div>

                <div class="auth-field">
                    <label for="password">Пароль</label>
                    <InputText id="password" @bind-Value="_loginRequest.Password" type="password" class="auth-input" />
                </div>

                <button type="submit" class="auth-button">Войти</button>
            </EditForm>

            @if (!string.IsNullOrWhiteSpace(_statusMessage))
            {
                <p class="auth-status">@_statusMessage</p>
            }

            <div class="auth-links">
                <NavLink href="/register">Нет аккаунта? Зарегистрироваться</NavLink>
                <NavLink href="/">На главную</NavLink>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly LoginRequest _loginRequest = new()
    {
        EmailOrUsername = string.Empty,
        Password = string.Empty
    };

    private string _statusMessage = string.Empty;

    private async Task HandleLoginSubmitAsync()
    {
        var response = await Http.PostAsJsonAsync(ApiRoutes.Auth.Login, _loginRequest);
        var content = await response.Content.ReadFromJsonAsync<LoginResponse>();

        if (response.IsSuccessStatusCode && content?.IsLoggedIn is true && content?.AccessToken is not null)
        {
            Auth.Login(content.AccessToken);
            Nav.NavigateTo($"/users/{Auth.UserName}");
        }
        else
        {
            _statusMessage = content?.ErrorMessage ?? "Ошибка входа.";
        }
    }
}
