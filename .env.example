# DB
POSTGRES_DB=dbname
POSTGRES_USER=username
POSTGRES_PASSWORD=password

# Connection string
Environment=ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=dbname;Username=username;Password=password

# JWT
Environment=JwtSettings__SecretKey=123456789012345678901234567890123456789

# CORS
Environment=Cors__AllowedOrigins__0=http://your.website
