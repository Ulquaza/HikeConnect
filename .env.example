# DB
POSTGRES_DB=dbname
POSTGRES_USER=username
POSTGRES_PASSWORD=password

# Connection string
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=dbname;Username=username;Password=password

# JWT
JwtSettings__SecretKey=123456789012345678901234567890123456789
JwtSettings__Issuer=Issuer
JwtSettings__Audience=Audience
JwtSettings__AccessTokenExpirationMinutes=30
JwtSettings__RefreshTokenExpirationDays=7

# CORS
Cors__AllowedOrigins__0=http://your.website
